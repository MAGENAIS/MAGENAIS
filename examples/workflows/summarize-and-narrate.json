{
  "id": "example-research-summarize-narrate",
  "name": "Research a topic, then narrate the findings",
  "graph": {
    "nodes": [
      {
        "id": "research1",
        "type": "research",
        "label": "Gather Sources",
        "config": { "sources": ["semanticscholar", "openalex", "arxiv"], "limitPerSource": 6 },
        "inputs": { "query": "quantum error correction 2026" },
        "enabled": true
      },
      {
        "id": "speech1",
        "type": "speech",
        "label": "Narrate Summary",
        "config": { "voice": "alloy" },
        "inputs": { "text": "${research1.summary}" },
        "enabled": true
      }
    ],
    "edges": [
      { "from": "research1", "to": "speech1" }
    ]
  }
}
